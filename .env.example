# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL 16) ───────────────────────────
# Local dev defaults. In prod, override with strong credentials.
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/asistencia?schema=public
DB_NAME=asistencia
DB_USER=app_user
DB_PASSWORD=app_password

# ── Cache / Sessions / Queue (Redis 7) ─────────────────
# Single URL — use logical DBs for separation (see below).
REDIS_URL=redis://:redispassword@localhost:6379/0
# Logical DB assignments (0=app, 1=refresh tokens, 2=activation, 3=bullmq)
REDIS_PASSWORD=redispassword
REDIS_REFRESH_DB=1
REDIS_ACTIVATION_DB=2
REDIS_BULLMQ_DB=3

# ── JWT (RS256) ────────────────────────────────────────
# Generate keys with:
#   openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#
# In dev, paste the PEM contents (with BEGIN/END lines) below.
# In prod, mount files at JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH.
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Optional: path to PEM files (used in prod via Docker secrets)
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public.pem

# ── Password hashing (Argon2id) ───────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── Cloudinary (file storage for logos) ────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=asistencia-saas

# ── Multi-tenancy ──────────────────────────────────────
# Root domain used to extract subdomain (institution slug) from request host.
# In dev: localhost (with subdomains like celsius.app.localhost)
# In prod: app.com (with subdomains like celsius.app.com)
ROOT_DOMAIN=localhost
# Cookie domain for shared cookies across subdomains. In prod use ".app.com" (leading dot)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── Rate limiting ──────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Web (Vite) ─────────────────────────────────────────
# Public URL where the browser hits the API. In dev: same-origin via nginx proxy.
# In prod: https://app.com
VITE_API_URL=/api

# ── Deploy (VPS) ──────────────────────────────────────
# Used by the GitHub Actions deploy workflow and infra/scripts/deploy.sh.
DEPLOY_HOST=
DEPLOY_USER=deploy
DEPLOY_KEY_PATH=
