# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL 16) ───────────────────────────
DATABASE_URL=postgresql://asistencia:asistencia@localhost:5432/asistencia_saas?schema=public

# ── Cache / Sessions (Redis 7) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) ────────────────────────────────────────
# Generate keys with: openssl genpkey -algorithm RSA -out jwt-private.pem -pkeyopt rsa_keygen_bits:2048
#                    openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# Paste the PEM contents below (including BEGIN/END lines)
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Password hashing (Argon2id) ───────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── Cloudinary (file storage for images) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=asistencia-saas

# ── Multi-tenancy ──────────────────────────────────────
# Root domain used to extract subdomain (institution slug) from request host
ROOT_DOMAIN=localhost
