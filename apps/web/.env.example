# Vite env. Loaded by Vite at dev/build time. Prefix with VITE_.
# API base URL. In dev, leave empty so requests go through the Vite proxy (/api).
# In prod, set to the API origin (e.g. https://api.app.com).
VITE_API_URL=
VITE_API_PREFIX=/api/v1

# Default locale for the SPA.
VITE_DEFAULT_LOCALE=es

# Toggle the dev-only tools (React Query devtools, axe, etc.).
VITE_ENABLE_DEVTOOLS=true
