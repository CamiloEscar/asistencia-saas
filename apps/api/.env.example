# ── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── API URL prefix (mounted at /api/v1 by main.ts) ─────
API_PREFIX=api/v1

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins. In dev this is
# http://localhost:5173 and *.app.localhost on various ports.
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL 16) ───────────────────────────
DATABASE_URL=postgresql://asistencia:asistencia@localhost:5432/asistencia_saas?schema=public
DATABASE_URL_ADMIN=postgresql://asistencia:asistencia@localhost:5432/asistencia_saas?schema=public

# ── Cache / Sessions (Redis 7) ─────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_REFRESH_DB=1
REDIS_ACTIVATION_DB=2
REDIS_BULLMQ_DB=3

# ── JWT (RS256) ────────────────────────────────────────
# PEM contents of the RS256 keypair. Generated on first boot by KeyManager
# if these are empty (and the files at JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH
# are missing).
JWT_PUBLIC_KEY=""
JWT_PRIVATE_KEY=""
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# How long the activation/set-password token is valid (default 48h).
JWT_ACTIVATION_TTL=48h

# ── Password hashing (Argon2id) ───────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── Cookies ────────────────────────────────────────────
# Lax per design #186 Q3. Secure in production.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_ACCESS_NAME=asistencia_access
COOKIE_REFRESH_NAME=asistencia_refresh

# ── Cloudinary (institution logos) ─────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=asistencia-saas

#  Throttler (per-user / per-IP rate limiting) 
THROTTLE_TTL=60
THROTTLE_LIMIT=100
