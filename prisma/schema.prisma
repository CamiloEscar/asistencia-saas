// Prisma schema for asistencia-saas — single-tenant edition.
//
// One institution per deploy. No RLS, no institutionId FK on business tables.
// Deploy a new project copy for each institution.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum SessionStatus {
  SCHEDULED
  OPEN
  CLOSED
  CANCELLED
  COMPLETED
}

enum RefreshTokenStatus {
  active
  used
  revoked
}

// ─── AppConfig (single-row institution config) ───────────────────────────

model AppConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(200)
  timezone  String   @default("America/Argentina/Buenos_Aires") @db.VarChar(100)
  logoUrl   String?  @db.Text
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("app_config")
}

// ─── User (all roles) ────────────────────────────────────────────────────

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique @db.Citext
  passwordHash String?    @db.Text
  fullName     String     @db.VarChar(200)
  role         UserRole
  status       UserStatus @default(ACTIVE)

  // Student-specific fields (null for non-students)
  legajo    String?   @unique @db.VarChar(20)
  phone     String?   @db.VarChar(30)
  birthDate DateTime? @db.Date
  career    String?   @db.VarChar(100)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  taughtCourses  CourseTeacher[]
  enrollments    Enrollment[]
  attendanceRecs AttendanceRecord[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]

  @@index([role])
  @@index([status])
  @@index([fullName])
  @@index([deletedAt])
  @@map("users")
}

// ─── Subject (academic topic) ────────────────────────────────────────────

model Subject {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(200)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  courses Course[]

  @@index([deletedAt])
  @@map("subjects")
}

// ─── Course (an offering of a subject for a semester) ───────────────────

model Course {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId                 String    @db.Uuid
  code                      String    @unique @db.VarChar(20)
  name                      String    @db.VarChar(200)
  description               String?   @db.Text
  semester                  String    @db.VarChar(20)
  startDate                 DateTime  @db.Date
  endDate                   DateTime  @db.Date
  schedule                  Json
  defaultSessionDurationMin Int       @default(80)
  createdAt                 DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt                 DateTime? @db.Timestamptz(6)

  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teachers    CourseTeacher[]
  enrollments Enrollment[]
  sessions    ClassSession[]

  @@index([semester])
  @@index([subjectId])
  @@index([deletedAt])
  @@map("courses")
}

// ─── CourseTeacher (m:n) ────────────────────────────────────────────────

model CourseTeacher {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId  String   @db.Uuid
  teacherId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@unique([courseId, teacherId])
  @@index([teacherId])
  @@index([courseId])
  @@map("course_teachers")
}

// ─── Enrollment (student ↔ course, m:n) ─────────────────────────────────

model Enrollment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId  String   @db.Uuid
  studentId String   @db.Uuid
  enrolledAt DateTime @default(now()) @db.Timestamptz(6)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([courseId])
  @@map("enrollments")
}

// ─── ClassSession ────────────────────────────────────────────────────────

model ClassSession {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String        @db.Uuid
  scheduledAt DateTime      @db.Timestamptz(6)
  durationMin Int
  topic       String?       @db.VarChar(500)
  status      SessionStatus @default(SCHEDULED)
  createdBy   String        @db.Uuid
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)

  course     Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendance AttendanceRecord[]

  @@unique([courseId, scheduledAt])
  @@index([scheduledAt(sort: Desc)])
  @@index([status, scheduledAt(sort: Desc)])
  @@map("class_sessions")
}

// ─── AttendanceRecord ────────────────────────────────────────────────────

model AttendanceRecord {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String           @db.Uuid
  studentId         String           @db.Uuid
  status            AttendanceStatus @default(PRESENT)
  justificationText String?          @db.VarChar(500)
  evidenceUrl       String?          @db.Text
  recordedBy        String           @db.Uuid
  recordedAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User         @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([sessionId, studentId])
  @@index([studentId, recordedAt(sort: Desc)])
  @@index([recordedAt(sort: Desc)])
  @@index([sessionId])
  @@map("attendance_records")
}

// ─── RefreshToken ────────────────────────────────────────────────────────

model RefreshToken {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @db.Uuid
  jti       String             @unique @db.VarChar(64)
  familyId  String             @db.Uuid
  tokenHash String?            @db.VarChar(64)
  status    RefreshTokenStatus @default(active)
  issuedAt  DateTime           @default(now()) @db.Timestamptz(6)
  expiresAt DateTime           @db.Timestamptz(6)
  revokedAt DateTime?          @db.Timestamptz(6)
  userAgent String?            @db.Text
  ipAddress String?            @db.Inet

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── AuditLog (append-only) ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String   @db.VarChar(100)
  entityType  String   @db.VarChar(50)
  entityId    String?  @db.Uuid
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?  @db.Inet
  userAgent   String?  @db.Text
  requestId   String?  @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_log")
}
