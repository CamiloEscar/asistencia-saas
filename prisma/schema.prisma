// Prisma schema for asistencia-saas (Hito 1 / attendance-mvp).
//
// Multi-tenant SaaS for educational institutions. Every tenant-scoped model
// carries an `institutionId` FK that backs the RLS policies (see migration).
// Composite indexes start with `institutionId` to keep RLS planner-friendly.
//
// Design reference: engram `sdd/attendance-mvp/design` (#186) §4.1.
// Spec: engram `sdd/attendance-mvp/spec/*`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum InstitutionStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  TEACHER
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum SessionStatus {
  SCHEDULED
  OPEN
  CLOSED
  CANCELLED
}

enum RefreshTokenStatus {
  active
  used
  revoked
}

// ─── Institution (tenant) ────────────────────────────────────────────────

model Institution {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String            @db.VarChar(200)
  subdomain String            @unique @db.VarChar(63)
  status    InstitutionStatus @default(ACTIVE)
  plan      String            @default("FREE") @db.VarChar(50)
  timezone  String            @default("America/Argentina/Buenos_Aires") @db.VarChar(100)
  logoUrl   String?           @db.Text
  createdAt DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt DateTime          @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?         @db.Timestamptz(6)

  users     User[]
  subjects  Subject[]
  courses   Course[]
  auditLogs AuditLog[]

  @@index([status])
  @@index([deletedAt])
  @@map("institutions")
}

// ─── User (all roles live here) ──────────────────────────────────────────

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String?    @db.Uuid // null for SUPER_ADMIN (cross-tenant)
  email         String     @db.Citext
  passwordHash  String?    @db.Text // null until set-password flow completes
  fullName      String     @db.VarChar(200)
  role          UserRole
  status        UserStatus @default(ACTIVE)

  // Student-specific fields (null for non-students)
  legajo    String?   @db.VarChar(20)
  phone     String?   @db.VarChar(30)
  birthDate DateTime? @db.Date
  career    String?   @db.VarChar(100)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  institution    Institution?      @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  taughtCourses  CourseTeacher[]
  enrollments    Enrollment[]
  attendanceRecs AttendanceRecord[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]

  // Email is unique per institution (citext makes it case-insensitive).
  // For SUPER_ADMIN (institutionId = NULL), the email is unique globally.
  @@unique([institutionId, email])
  @@unique([institutionId, legajo])
  @@index([institutionId, role])
  @@index([institutionId, status])
  @@index([institutionId, fullName])
  @@index([institutionId, deletedAt])
  @@map("users")
}

// ─── Subject (academic topic) ────────────────────────────────────────────

model Subject {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String    @db.Uuid
  code          String    @db.VarChar(20)
  name          String    @db.VarChar(200)
  description   String?   @db.Text
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  courses     Course[]

  @@unique([institutionId, code])
  @@index([institutionId, deletedAt])
  @@map("subjects")
}

// ─── Course (an offering of a subject for a semester) ───────────────────

model Course {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId             String   @db.Uuid
  subjectId                 String   @db.Uuid
  code                      String   @db.VarChar(20)
  name                      String   @db.VarChar(200)
  description               String?  @db.Text
  semester                  String   @db.VarChar(20)
  startDate                 DateTime @db.Date
  endDate                   DateTime @db.Date
  schedule                  Json // [{ day: 0-6, startTime: "HH:mm", endTime: "HH:mm" }]
  defaultSessionDurationMin Int      @default(80)
  createdAt                 DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                 DateTime @updatedAt @db.Timestamptz(6)
  deletedAt                 DateTime? @db.Timestamptz(6)

  institution Institution    @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  subject     Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  teachers    CourseTeacher[]
  enrollments Enrollment[]
  sessions    ClassSession[]

  @@unique([institutionId, code])
  @@index([institutionId, semester])
  @@index([institutionId, subjectId])
  @@index([institutionId, deletedAt])
  @@map("courses")
}

// ─── CourseTeacher (m:n) ────────────────────────────────────────────────

model CourseTeacher {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String   @db.Uuid // denormalized for RLS
  courseId      String   @db.Uuid
  teacherId     String   @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@unique([courseId, teacherId])
  @@index([institutionId, teacherId])
  @@index([courseId])
  @@map("course_teachers")
}

// ─── Enrollment (student ↔ course, m:n) ─────────────────────────────────

model Enrollment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String   @db.Uuid
  courseId      String   @db.Uuid
  studentId     String   @db.Uuid
  enrolledAt    DateTime @default(now()) @db.Timestamptz(6)

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([courseId, studentId])
  @@index([institutionId, studentId])
  @@index([courseId])
  @@map("enrollments")
}

// ─── ClassSession (a scheduled or completed class meeting) ───────────────

model ClassSession {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String        @db.Uuid
  courseId      String        @db.Uuid
  scheduledAt   DateTime      @db.Timestamptz(6)
  durationMin   Int
  topic         String?       @db.VarChar(500)
  status        SessionStatus @default(SCHEDULED)
  createdBy     String        @db.Uuid
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(6)

  course     Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendance AttendanceRecord[]

  @@unique([courseId, scheduledAt])
  @@index([institutionId, scheduledAt(sort: Desc)])
  @@index([institutionId, status, scheduledAt(sort: Desc)])
  @@map("class_sessions")
}

// ─── AttendanceRecord (one row per student per session) ─────────────────

model AttendanceRecord {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId     String           @db.Uuid
  sessionId         String           @db.Uuid
  studentId         String           @db.Uuid
  status            AttendanceStatus @default(PRESENT)
  justificationText String?          @db.VarChar(500)
  recordedBy        String           @db.Uuid
  recordedAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User         @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@unique([sessionId, studentId])
  @@index([institutionId, studentId, recordedAt(sort: Desc)])
  @@index([institutionId, recordedAt(sort: Desc)])
  @@index([sessionId])
  @@map("attendance_records")
}

// ─── RefreshToken (DB mirror of Redis state, defense-in-depth) ──────────

model RefreshToken {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @db.Uuid
  jti       String             @unique @db.VarChar(64)
  familyId  String             @db.Uuid
  status    RefreshTokenStatus @default(active)
  issuedAt  DateTime           @default(now()) @db.Timestamptz(6)
  expiresAt DateTime           @db.Timestamptz(6)
  revokedAt DateTime?          @db.Timestamptz(6)
  userAgent String?            @db.Text
  ipAddress String?            @db.Inet

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── AuditLog (append-only) ─────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId String?  @db.Uuid // null for super-admin global actions
  actorUserId   String?  @db.Uuid
  action        String   @db.VarChar(100)
  entityType    String   @db.VarChar(50)
  entityId      String?  @db.Uuid
  beforeJson    Json?
  afterJson     Json?
  ipAddress     String?  @db.Inet
  userAgent     String?  @db.Text
  requestId     String?  @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  institution Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  actor       User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([institutionId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_log")
}
