# Production env vars. Copy to infra/docker/.env and fill in real values.
# DO NOT commit the populated version — only this template.

# ── Database ───────────────────────────────────────────
DB_NAME=asistencia
DB_USER=app_user
DB_PASSWORD=change-me-to-strong-random-string-32-chars-min
DATABASE_URL=postgresql://app_user:DB_PASSWORD@pgbouncer:6432/asistencia?schema=public

# ── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=change-me-to-another-strong-random-string
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_REFRESH_DB=1
REDIS_ACTIVATION_DB=2
REDIS_BULLMQ_DB=3

# ── JWT (RS256) — keys mounted as Docker secrets ─────
# Place jwt-private.pem and jwt-public.pem at:
#   infra/docker/secrets/
# The compose file references them via the `secrets:` directive.
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
# Production CORS — list of allowed origins (comma-separated)
CORS_ORIGINS=https://app.com,https://*.app.com

# ── Cookie config ─────────────────────────────────────
COOKIE_DOMAIN=.app.com
COOKIE_SECURE=true

# ── Rate limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Cloudinary (logo uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=asistencia-saas

# ── Web build arg ──────────────────────────────────────
# Injected at build time as VITE_API_URL (the FE reads this for the API base URL)
VITE_API_URL=https://app.com
